{
	"name": "ds_esr_actives_sip_source",
	"properties": {
		"description": "ESR Actives source 1 of 3: StaffInPost CSV. All files matching StaffInPost_*.csv in p_folder are read (wildcard) — supports any number of per-VPD files. Payroll Name first 3 chars is used to derive TRUST_VPD.",
		"linkedServiceName": {
			"referenceName": "ls_adls_stnhsdwidev",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"p_folder": {
				"type": "String",
				"defaultValue": "esr/2026-03-19"
			}
		},
		"annotations": [],
		"type": "DelimitedText",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"folderPath": {
					"value": "@dataset().p_folder",
					"type": "Expression"
				},
				"fileSystem": "raw"
			},
			"columnDelimiter": ",",
			"rowDelimiter": "\n",
			"escapeChar": "\\",
			"firstRowAsHeader": true,
			"quoteChar": "\""
		},
		"schema": []
	},
	"type": "Microsoft.DataFactory/factories/datasets"
}