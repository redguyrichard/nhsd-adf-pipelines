		"linkedServiceName": {
			"referenceName": "ls_adls_stnhsdwidev",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"p_archive_folder": {
				"type": "String",
				"defaultValue": "esr/20260319"
			}
		},
		"annotations": [],
		"type": "DelimitedText",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"folderPath": {
					"value": "@dataset().p_archive_folder",
					"type": "Expression"
				},
				"fileSystem": "archive"
			},
			"columnDelimiter": ",",
			"rowDelimiter": "\n",
			"escapeChar": "\\",
			"firstRowAsHeader": true,
			"quoteChar": "\""
		},
		"schema": []
	},
	"type": "Microsoft.DataFactory/factories/datasets"
}