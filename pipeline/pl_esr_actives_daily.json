					"dataset": {
						"referenceName": "ds_esr_actives_conformed_folder",
						"type": "DatasetReference",
						"parameters": {
							"p_folder": {
								"value": "@concat(pipeline().parameters.p_staff_all_output_folder, '/_working')",
								"type": "Expression"
							}
						}
					},
					"enableLogging": false,
					"storeSettings": {
						"type": "AzureBlobFSReadSettings",
						"recursive": true,
						"wildcardFileName": "*"
					}
				}
			},
