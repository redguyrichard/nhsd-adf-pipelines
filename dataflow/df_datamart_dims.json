{
	"name": "df_datamart_dims",
	"properties": {
		"description": "Loads Dim_Organisation, Dim_Person and Dim_Position from conformed ActiveStaffFull CSV. Upserts on natural keys. CostCentre = WORKPLACE_ORG_NAME (temp key). Org L2-L5 = NULL until conformed CSV is extended.",
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_datamart_conformed_activestaff",
						"type": "DatasetReference"
					},
					"name": "SourceConformed",
					"description": "Conformed ActiveStaffFull CSV — output of pl_esr_actives_daily."
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_datamart_sql_Dim_Organisation",
						"type": "DatasetReference"
					},
					"name": "SinkDimOrganisation",
					"description": "Upsert Dim_Organisation on CostCentre key."
				},
				{
					"dataset": {
						"referenceName": "ds_datamart_sql_Dim_Person",
						"type": "DatasetReference"
					},
					"name": "SinkDimPerson",
					"description": "Upsert Dim_Person on PUID key (SCD Type 1 — overwrite on re-load)."
				},
				{
					"dataset": {
						"referenceName": "ds_datamart_sql_Dim_Position",
						"type": "DatasetReference"
					},
					"name": "SinkDimPosition",
					"description": "Upsert Dim_Position on PositionNumber key."
				}
			],
			"transformations": [
				{
					"name": "DeduplicateOrg"
				},
				{
					"name": "SelectOrg"
				},
				{
					"name": "FilterValidPositions"
				},
				{
					"name": "DeduplicatePosition"
				},
				{
					"name": "SelectPosition"
				},
				{
					"name": "SelectPerson"
				},
				{
					"name": "AlterRowOrg"
				},
				{
					"name": "AlterRowPerson"
				},
				{
					"name": "AlterRowPosition"
				}
			],
			"scriptLines": [
				"source(output(",
				"          PERSON_UNIQUE_IDENTIFIER_PUID as string,",
				"          EMPLOYEE_NUMBER as string,",
				"          FORENAME as string,",
				"          SURNAME as string,",
				"          TITLE as string,",
				"          GENDER as string,",
				"          DATE_OF_BIRTH as string,",
				"          MARITAL_PARTNERSHIP_STATUS as string,",
				"          LATEST_START_DATE as string,",
				"          NHS_ENTRY_DATE as string,",
				"          ORIGINAL_HIRE_DATE as string,",
				"          TRUST_VPD as string,",
				"          ASSIGNMENT_NUMBER as string,",
				"          PRIMARY_JOB as string,",
				"          OFFICE_LOCATION as string,",
				"          ASSIGNMENT_TYPE as string,",
				"          ASSIGNMENT_STATUS as string,",
				"          FTE as string,",
				"          DATE_STARTED_IN_JOB as string,",
				"          DATE_LEFT_JOB as string,",
				"          POSITION_NUMBER as string,",
				"          KNOWN_AS_JOB_TITLE as string,",
				"          FORMAL_JOB_TITLE as string,",
				"          AREA_OF_WORK as string,",
				"          JOB_STAFF_GROUP as string,",
				"          JOB_ROLE as string,",
				"          OCCUPATION_CODE as string,",
				"          HIRING_STATUS as string,",
				"          WORKPLACE_ORG_NAME as string,",
				"          DEPARTMENT as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> SourceConformed",
				"SourceConformed aggregate(groupBy(WORKPLACE_ORG_NAME,",
				"          DEPARTMENT,",
				"          TRUST_VPD),",
				"     RowCount = count()) ~> DeduplicateOrg",
				"DeduplicateOrg select(mapColumn(",
				"          CostCentre = WORKPLACE_ORG_NAME,",
				"          Department = DEPARTMENT,",
				"          TrustVPD = TRUST_VPD",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SelectOrg",
				"SourceConformed filter(!isNull(POSITION_NUMBER) && length(trim(POSITION_NUMBER)) > 0) ~> FilterValidPositions",
				"FilterValidPositions aggregate(groupBy(POSITION_NUMBER),",
				"     KnownAsJobTitle = first(KNOWN_AS_JOB_TITLE),",
				"          FormalJobTitle = first(FORMAL_JOB_TITLE),",
				"          AreaOfWork = first(AREA_OF_WORK),",
				"          JobStaffGroup = first(JOB_STAFF_GROUP),",
				"          JobRole = first(JOB_ROLE),",
				"          OccupationCode = first(OCCUPATION_CODE),",
				"          HiringStatus = first(HIRING_STATUS)) ~> DeduplicatePosition",
				"DeduplicatePosition select(mapColumn(",
				"          PositionNumber = POSITION_NUMBER,",
				"          KnownAsJobTitle,",
				"          FormalJobTitle,",
				"          AreaOfWork,",
				"          JobStaffGroup,",
				"          JobRole,",
				"          OccupationCode,",
				"          HiringStatus",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SelectPosition",
				"SourceConformed select(mapColumn(",
				"          PUID = PERSON_UNIQUE_IDENTIFIER_PUID,",
				"          EmployeeNumber = EMPLOYEE_NUMBER,",
				"          Forename = FORENAME,",
				"          Surname = SURNAME,",
				"          Title = TITLE,",
				"          Gender = GENDER,",
				"          DateOfBirth = DATE_OF_BIRTH,",
				"          MaritalStatus = MARITAL_PARTNERSHIP_STATUS,",
				"          LatestStartDate = LATEST_START_DATE,",
				"          NHSEntryDate = NHS_ENTRY_DATE,",
				"          OriginalHireDate = ORIGINAL_HIRE_DATE,",
				"          TrustVPD = TRUST_VPD",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SelectPerson",
				"SelectOrg alterRow(upsertIf(true())) ~> AlterRowOrg",
				"SelectPerson alterRow(upsertIf(true())) ~> AlterRowPerson",
				"SelectPosition alterRow(upsertIf(true())) ~> AlterRowPosition",
				"AlterRowOrg sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          OrgKey as any,",
				"          CostCentre as any,",
				"          Service as any,",
				"          Division as any,",
				"          Directorate as any,",
				"          CareGroup as any,",
				"          Department as any,",
				"          TrustVPD as any,",
				"          CreatedDate as timestamp,",
				"          ModifiedDate as timestamp,",
				"          IsActive as any",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['CostCentre'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CostCentre,",
				"          Department,",
				"          TrustVPD",
				"     )) ~> SinkDimOrganisation",
				"AlterRowPerson sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          PersonKey as any,",
				"          PUID as any,",
				"          EmployeeNumber as any,",
				"          Forename as any,",
				"          Surname as any,",
				"          Title as any,",
				"          Gender as any,",
				"          DateOfBirth as timestamp,",
				"          MaritalStatus as any,",
				"          LatestStartDate as timestamp,",
				"          NHSEntryDate as timestamp,",
				"          OriginalHireDate as timestamp,",
				"          LengthOfServiceYears as decimal(5,2),",
				"          TrustVPD as any,",
				"          AgeBand as any,",
				"          CreatedDate as timestamp,",
				"          ModifiedDate as timestamp,",
				"          IsActive as any",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['PUID'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          PUID,",
				"          EmployeeNumber,",
				"          Forename,",
				"          Surname,",
				"          Title,",
				"          Gender,",
				"          DateOfBirth,",
				"          MaritalStatus,",
				"          LatestStartDate,",
				"          NHSEntryDate,",
				"          OriginalHireDate,",
				"          TrustVPD",
				"     )) ~> SinkDimPerson",
				"AlterRowPosition sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          PositionKey as any,",
				"          PositionNumber as any,",
				"          KnownAsJobTitle as any,",
				"          FormalJobTitle as any,",
				"          AreaOfWork as any,",
				"          SubjectiveCode as any,",
				"          JobStaffGroup as any,",
				"          JobRole as any,",
				"          OccupationCode as any,",
				"          FrontlineHealthcareWorker as any,",
				"          PayGrade as any,",
				"          HiringStatus as any,",
				"          CreatedDate as timestamp,",
				"          ModifiedDate as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['PositionNumber'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          PositionNumber,",
				"          KnownAsJobTitle,",
				"          FormalJobTitle,",
				"          AreaOfWork,",
				"          JobStaffGroup,",
				"          JobRole,",
				"          OccupationCode,",
				"          HiringStatus",
				"     )) ~> SinkDimPosition"
			]
		}
	}
}