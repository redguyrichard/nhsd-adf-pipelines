{
	"name": "df_transform_esr_actives",
	"properties": {
		"description": "Three-source join: StaffInPost + PositionsAnalysis (LEFT on Position Number = Position) + Learning aggregated (LEFT on Employee Number = Applicant Number). TRUST_VPD derived from file name. Dual output branches: SelectActiveStaff (full spec V0.1) and SelectPatientPrivacy (subset spec V0.2). VPD filter is LAST on each branch.",
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_esr_actives_sip_source",
						"type": "DatasetReference"
					},
					"name": "SourceSIP",
					"description": "StaffInPost CSV: person, assignment, supervisor and employment data. Payroll Name first 3 chars used to derive TRUST_VPD. Multi-VPD file — rows for all trusts in the upload."
				},
				{
					"dataset": {
						"referenceName": "ds_esr_actives_pos_source",
						"type": "DatasetReference"
					},
					"name": "SourcePOS",
					"description": "PositionsAnalysis CSV: position metadata. LEFT-joined to SourceSIP on {Position Number} = Position. Provides formal job title, staff group, occupation code, hiring status and org hierarchy."
				},
				{
					"dataset": {
						"referenceName": "ds_esr_actives_lrn_source",
						"type": "DatasetReference"
					},
					"name": "SourceLRN",
					"description": "Learning CSV: training and e-learning records. Aggregated to one row per employee before joining to prevent row duplication."
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_esr_actives_staff_all_output",
						"type": "DatasetReference"
					},
					"name": "SinkStaffAll",
					"description": "Write Active Staff Full all-VPD CSV to conformed/actives/staff/all/. No filter — every employee row from every trust. Schema: Active Staff Data Product Mapping Spec V0.1."
				},
				{
					"dataset": {
						"referenceName": "ds_esr_actives_staff_vpd_output",
						"type": "DatasetReference"
					},
					"name": "SinkStaffVPD",
					"description": "Write Active Staff Full VPD-filtered CSV to conformed/actives/staff/<vpd_code>/. Schema: Active Staff Data Product Mapping Spec V0.1."
				},
				{
					"dataset": {
						"referenceName": "ds_esr_actives_pp_all_output",
						"type": "DatasetReference"
					},
					"name": "SinkPPAll",
					"description": "Write Patient Privacy Workforce all-VPD CSV to conformed/actives/pp/all/. No filter — every employee row from every trust. Schema: Active Patient Privacy Staff Data Product Mapping Spec V0.2."
				},
				{
					"dataset": {
						"referenceName": "ds_esr_actives_pp_vpd_output",
						"type": "DatasetReference"
					},
					"name": "SinkPPVPD",
					"description": "Write Patient Privacy Workforce VPD-filtered CSV to conformed/actives/pp/<vpd_code>/. Schema: Active Patient Privacy Staff Data Product Mapping Spec V0.2."
				}
			],
			"transformations": [
				{
					"name": "AggregateLRN",
					"description": "Aggregate Learning records by Applicant Number. Takes last() of Course, Completion Date, Enrollment Status and Score — one row per employee for the join."
				},
				{
					"name": "JoinSIPPOS",
					"description": "LEFT JOIN: StaffInPost joined to PositionsAnalysis on {Position Number} = Position. All SIP rows retained. Position columns are null if no matching position exists."
				},
				{
					"name": "JoinAll",
					"description": "LEFT JOIN: JoinSIPPOS result joined to AggregateLRN on {Employee Number} = {Applicant Number}. All employee rows retained. Learning columns are null for employees with no training records."
				},
				{
					"name": "DeriveFields",
					"description": "Attribute conformance: PUID from ESR source column, FORENAME/SURNAME preserved as-is from ESR (not upper-cased), DATE_OF_BIRTH reformat, FTE to 2dp, OCCUPATION_CODE 3-digit 0-pad, TRUST_VPD from Payroll Name first 3 chars, DATE_LEFT_JOB_ESR and DATE_STARTED_IN_JOB_ESR from Asg Effective dates. Null placeholders for future/no-source fields."
				},
				{
					"name": "SelectActiveStaff",
					"description": "Branch 1: maps derived fields to Active Staff Full output schema per Mapping Spec V0.1. DATE_LEFT_JOB is blank. Includes Prof Reg/DBS/Visa fields (all null/orange). Learning columns excluded."
				},
				{
					"name": "SelectPatientPrivacy",
					"description": "Branch 2: maps derived fields to Patient Privacy Workforce output schema per Mapping Spec V0.2 (subset of V0.1). DATE_LEFT_JOB from Asg Effective End Date. Prof Reg/DBS/Visa columns excluded entirely."
				},
				{
					"name": "FilterVPDStaff",
					"description": "VPD filter for Active Staff Full branch. Applied AFTER SinkStaffAll so all-VPD output is fully written first."
				},
				{
					"name": "FilterVPDPP",
					"description": "VPD filter for Patient Privacy Workforce branch. Applied AFTER SinkPPAll so all-VPD output is fully written first."
				}
			],
			"scriptLines": [
				"parameters{",
				"     vpd_code as integer (185)",
				"}",
				"source(output(",
				"          PUID as string,",
				"          {Employee Number} as string,",
				"          {Assignment Number} as string,",
				"          {Last Name} as string,",
				"          {First Name} as string,",
				"          {Middle Name} as string,",
				"          Title as string,",
				"          {Employee Person Type} as string,",
				"          {Person Type} as string,",
				"          Gender as string,",
				"          {Marital Status} as string,",
				"          {NI Number} as string,",
				"          {Date of Birth} as string,",
				"          {Address Line 1} as string,",
				"          {Address Line 2} as string,",
				"          {Address Line 3} as string,",
				"          {Town or City} as string,",
				"          County as string,",
				"          {Postal Code} as string,",
				"          {Email Address} as string,",
				"          Supervisor as string,",
				"          {Supervisor Employee Number} as string,",
				"          {Supervisor Assignment Number} as string,",
				"          {Supervisor Email Address} as string,",
				"          Location as string,",
				"          {Payroll Name} as string,",
				"          {Position Number} as string,",
				"          {Assignment Category} as string,",
				"          {Assignment Status} as string,",
				"          FTE as string,",
				"          {Latest Start Date} as string,",
				"          {NHS Entry Date} as string,",
				"          {Original Hire Date} as string,",
				"          {Start Date in Position} as string,",
				"          {Primary Assignment} as string,",
				"          {Asg Effective Start Date} as string,",
				"          {Asg Effective End Date} as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> SourceSIP",
				"source(output(",
				"          Position as string,",
				"          {Occupation Code} as string,",
				"          {Hiring Status} as string,",
				"          {Position Title} as string,",
				"          {Position Title (Summary)} as string,",
				"          {Primary Area of Work} as string,",
				"          {Secondary Area of Work} as string,",
				"          {Area Of Work} as string,",
				"          {Workplace Org Name} as string,",
				"          {Location Name} as string,",
				"          {Staff Group} as string,",
				"          Role as string,",
				"          {Org L3} as string,",
				"          {Org L4} as string,",
				"          {Org L5} as string,",
				"          {Org L6} as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> SourcePOS",
				"source(output(",
				"          {Applicant Number} as string,",
				"          Category as string,",
				"          Course as string,",
				"          {Enrollment Status} as string,",
				"          {Completion Date} as string,",
				"          Score as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> SourceLRN",
				"SourceLRN aggregate(groupBy({Applicant Number}),",
				"     LATEST_LEARNING_COURSE = last(Course),",
				"          LATEST_LEARNING_DATE = last({Completion Date}),",
				"          LEARNING_STATUS = last({Enrollment Status}),",
				"          LEARNING_SCORE = last(toString(Score))) ~> AggregateLRN",
				"SourceSIP, SourcePOS join({Position Number} == Position,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> JoinSIPPOS",
				"JoinSIPPOS, AggregateLRN join({Employee Number} == {Applicant Number},",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> JoinAll",
				"JoinAll derive(PERSON_UNIQUE_IDENTIFIER_PUID = trim(PUID),",
				"          FORENAME = trim({First Name}),",
				"          SURNAME = trim({Last Name}),",
				"          DATE_OF_BIRTH = iif(",
				"        isNull({Date of Birth}) || length(trim({Date of Birth})) == 0,",
				"        '',",
				"        toString(toDate({Date of Birth}, 'dd-MMM-yy'), 'dd/MM/yyyy')",
				"    ),",
				"          POSTAL_CODE = upper(trim({Postal Code})),",
				"          LATEST_START_DATE = iif(",
				"        isNull({Latest Start Date}) || length(trim({Latest Start Date})) == 0,",
				"        '',",
				"        left(trim({Latest Start Date}), 10)",
				"    ),",
				"          PRIMARY_JOB = iif(",
				"        upper(trim({Primary Assignment})) == 'Y' ||",
				"        upper(trim({Primary Assignment})) == 'YES' ||",
				"        trim({Primary Assignment}) == '1',",
				"        'Yes',",
				"        'No'",
				"    ),",
				"          OCCUPATION_CODE_PADDED = iif(",
				"        isNull({Occupation Code}) || length(trim({Occupation Code})) == 0,",
				"        '',",
				"        iif(",
				"            length(trim({Occupation Code})) < 3,",
				"            lpad(trim({Occupation Code}), 3, '0'),",
				"            trim({Occupation Code})",
				"        )",
				"    ),",
				"          TRUST_VPD = left(trim({Payroll Name}), 3),",
				"          FTE_FORMATTED = iif(",
				"        isNull(FTE) || length(trim(toString(FTE))) == 0,",
				"        '',",
				"        toString(toDecimal(FTE, 10, 2))",
				"    ),",
				"          DATE_LEFT_JOB_ESR = iif(",
				"        isNull({Asg Effective End Date}) || length(trim({Asg Effective End Date})) == 0,",
				"        '',",
				"        left(trim({Asg Effective End Date}), 10)",
				"    ),",
				"          DATE_STARTED_IN_JOB_ESR = iif(",
				"        isNull({Asg Effective Start Date}) || length(trim({Asg Effective Start Date})) == 0,",
				"        '',",
				"        left(trim({Asg Effective Start Date}), 10)",
				"    ),",
				"          TERMINATION_DATE = toString(null()),",
				"          LEAVE_START_DATE = toString(null()),",
				"          LEAVE_END_DATE = toString(null()),",
				"          NAME_OF_PARTNER_OR_SPOUSE = toString(null()),",
				"          OFFICE_LOCATION_ID = toString(null()),",
				"          OFFICE_LOCATION_ADDRESS = toString(null()),",
				"          LINE_MANAGER_PUID = toString(null()),",
				"          LINE_MANAGER_EMPLOYEE_NUMBER = toString(null()),",
				"          LINE_MANAGER_ASSIGNMENT_NUMBER = toString(null()),",
				"          LINE_MANAGER_EMAIL_ADDRESS = toString(null()),",
				"          LINE_MANAGER_POSITION = toString(null()),",
				"          LINE_MANAGER_NAME = toString(null()),",
				"          ASSIGNMENT_ADDRESS_1ST_LINE = toString(null()),",
				"          ASSIGNMENT_ADDRESS_2ND_LINE = toString(null()),",
				"          ASSIGNMENT_ADDRESS_3RD_LINE = toString(null()),",
				"          TOWN = toString(null()),",
				"          LOCATION_COUNTY = toString(null()),",
				"          POSTCODE = toString(null()),",
				"          COUNTRY = toString(null()),",
				"          LOCATION_DESCRIPTION = toString(null()),",
				"          EC_NAME = toString(null()),",
				"          EC_PHONE = toString(null()),",
				"          EC_ADDRESS = toString(null()),",
				"          EC_EMAIL = toString(null()),",
				"          EC_RELATIONSHIP = toString(null()),",
				"          NOK_FORENAME = toString(null()),",
				"          NOK_SURNAME = toString(null()),",
				"          NOK_PHONE = toString(null()),",
				"          NOK_EMAIL = toString(null()),",
				"          NOK_ADDRESS = toString(null()),",
				"          NOK_RELATIONSHIP = toString(null()),",
				"          DATE_LEFT_JOB_BLANK = toString(null()),",
				"          PROFESSIONAL_REGISTRATION_BODY = toString(null()),",
				"          PROFESSIONAL_REGISTRATION_STATUS = toString(null()),",
				"          PROFESSIONAL_REGISTRATION_STATE = toString(null()),",
				"          PROFESSIONAL_REGISTRATION_EXPIRY_DATE = toString(null()),",
				"          DBS_TYPE = toString(null()),",
				"          DBS_DATE = toString(null()),",
				"          DBS_CERTIFICATE_NUMBER = toString(null()),",
				"          DBS_RENEWAL_DATE = toString(null()),",
				"          COMPLIANT_DBS = toString(null()),",
				"          VISA_NUMBER_VIGNETTE = toString(null()),",
				"          VISA_TYPE = toString(null()),",
				"          VISA_ISSUE_DATE = toString(null()),",
				"          VISA_EXPIRY_DATE = toString(null()),",
				"          NHS_ENTRY_DATE_CLEAN = iif(",
				"        isNull({NHS Entry Date}) || length(trim({NHS Entry Date})) == 0,",
				"        '',",
				"        left(trim({NHS Entry Date}), 10)",
				"    ),",
				"          DEPARTMENT_DERIVED = trim(toString(byName(concat('Org L6', char(13))))),",
				"          PARENT_ORGANISATION_BLANK = toString(null())) ~> DeriveFields",
				"DeriveFields select(mapColumn(",
				"          PERSON_UNIQUE_IDENTIFIER_PUID,",
				"          EMPLOYEE_NUMBER = {Employee Number},",
				"          FORENAME,",
				"          OTHER_NAME_S = {Middle Name},",
				"          SURNAME,",
				"          TITLE = Title,",
				"          GENDER = Gender,",
				"          DATE_OF_BIRTH,",
				"          MARITAL_PARTNERSHIP_STATUS = {Marital Status},",
				"          NAME_OF_PARTNER_OR_SPOUSE,",
				"          PERSONAL_HOME_ADDRESS_LINE_1 = {Address Line 1},",
				"          PERSONAL_HOME_ADDRESS_LINE_2 = {Address Line 2},",
				"          PERSONAL_HOME_ADDRESS_LINE_3 = {Address Line 3},",
				"          TOWN_OR_CITY = {Town or City},",
				"          COUNTY = County,",
				"          POSTAL_CODE,",
				"          LATEST_START_DATE,",
				"          NHS_ENTRY_DATE = NHS_ENTRY_DATE_CLEAN,",
				"          ORIGINAL_HIRE_DATE = {Original Hire Date},",
				"          TRUST_VPD,",
				"          PERSON_TYPE = {Person Type},",
				"          EMPLOYEE_PERSON_TYPE = {Employee Person Type},",
				"          ASSIGNMENT_NUMBER = {Assignment Number},",
				"          PRIMARY_JOB,",
				"          OFFICE_LOCATION = Location,",
				"          EMAIL_ADDRESS = {Email Address},",
				"          DATE_STARTED_IN_JOB = DATE_STARTED_IN_JOB_ESR,",
				"          ASSIGNMENT_TYPE = {Assignment Category},",
				"          ASSIGNMENT_STATUS = {Assignment Status},",
				"          FTE = FTE_FORMATTED,",
				"          DATE_LEFT_JOB = DATE_LEFT_JOB_BLANK,",
				"          TERMINATION_DATE,",
				"          LEAVE_START_DATE,",
				"          LEAVE_END_DATE,",
				"          SUPERVISOR = Supervisor,",
				"          SUPERVISOR_EMPLOYEE_NUMBER = {Supervisor Employee Number},",
				"          SUPERVISOR_ASSIGNMENT_NUMBER = {Supervisor Assignment Number},",
				"          SUPERVISOR_EMAIL_ADDRESS = {Supervisor Email Address},",
				"          LINE_MANAGER_PUID,",
				"          LINE_MANAGER_EMPLOYEE_NUMBER,",
				"          LINE_MANAGER_ASSIGNMENT_NUMBER,",
				"          LINE_MANAGER_EMAIL_ADDRESS,",
				"          LINE_MANAGER_POSITION,",
				"          LINE_MANAGER_NAME,",
				"          POSITION_NUMBER = {Position Number},",
				"          FORMAL_JOB_TITLE = {Position Title (Summary)},",
				"          KNOWN_AS_JOB_TITLE = {Position Title},",
				"          AREA_OF_WORK = {Area Of Work},",
				"          JOB_STAFF_GROUP = {Staff Group},",
				"          JOB_ROLE = Role,",
				"          OCCUPATION_CODE = OCCUPATION_CODE_PADDED,",
				"          HIRING_STATUS = {Hiring Status},",
				"          WORKPLACE_ORG_NAME = {Workplace Org Name},",
				"          PRIMARY_AREA_OF_WORK = {Primary Area of Work},",
				"          SECONDARY_AREA_OF_WORK = {Secondary Area of Work},",
				"          DEPARTMENT = DEPARTMENT_DERIVED,",
				"          OFFICE_LOCATION_NAME = {Location Name},",
				"          OFFICE_LOCATION_ID,",
				"          OFFICE_LOCATION_ADDRESS,",
				"          ASSIGNMENT_ADDRESS_1ST_LINE,",
				"          ASSIGNMENT_ADDRESS_2ND_LINE,",
				"          ASSIGNMENT_ADDRESS_3RD_LINE,",
				"          TOWN,",
				"          LOCATION_COUNTY,",
				"          POSTCODE,",
				"          COUNTRY,",
				"          LOCATION_DESCRIPTION,",
				"          EC_NAME,",
				"          EC_PHONE,",
				"          EC_ADDRESS,",
				"          EC_EMAIL,",
				"          EC_RELATIONSHIP,",
				"          NOK_FORENAME,",
				"          NOK_SURNAME,",
				"          NOK_PHONE,",
				"          NOK_EMAIL,",
				"          NOK_ADDRESS,",
				"          NOK_RELATIONSHIP,",
				"          PROFESSIONAL_REGISTRATION_BODY,",
				"          PROFESSIONAL_REGISTRATION_STATUS,",
				"          PROFESSIONAL_REGISTRATION_STATE,",
				"          PROFESSIONAL_REGISTRATION_EXPIRY_DATE,",
				"          DBS_TYPE,",
				"          DBS_DATE,",
				"          DBS_CERTIFICATE_NUMBER,",
				"          DBS_RENEWAL_DATE,",
				"          COMPLIANT_DBS,",
				"          VISA_NUMBER_VIGNETTE,",
				"          VISA_TYPE,",
				"          VISA_ISSUE_DATE,",
				"          VISA_EXPIRY_DATE,",
				"          PARENT_ORGANISATION = PARENT_ORGANISATION_BLANK",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SelectActiveStaff",
				"DeriveFields select(mapColumn(",
				"          PERSON_UNIQUE_IDENTIFIER_PUID,",
				"          EMPLOYEE_NUMBER = {Employee Number},",
				"          FORENAME,",
				"          OTHER_NAME_S = {Middle Name},",
				"          SURNAME,",
				"          TITLE = Title,",
				"          GENDER = Gender,",
				"          DATE_OF_BIRTH,",
				"          MARITAL_PARTNERSHIP_STATUS = {Marital Status},",
				"          NAME_OF_PARTNER_OR_SPOUSE,",
				"          PERSONAL_HOME_ADDRESS_LINE_1 = {Address Line 1},",
				"          PERSONAL_HOME_ADDRESS_LINE_2 = {Address Line 2},",
				"          PERSONAL_HOME_ADDRESS_LINE_3 = {Address Line 3},",
				"          TOWN_OR_CITY = {Town or City},",
				"          COUNTY = County,",
				"          POSTAL_CODE,",
				"          LATEST_START_DATE,",
				"          NHS_ENTRY_DATE = NHS_ENTRY_DATE_CLEAN,",
				"          ORIGINAL_HIRE_DATE = {Original Hire Date},",
				"          TRUST_VPD,",
				"          PERSON_TYPE = {Person Type},",
				"          EMPLOYEE_PERSON_TYPE = {Employee Person Type},",
				"          ASSIGNMENT_NUMBER = {Assignment Number},",
				"          PRIMARY_JOB,",
				"          OFFICE_LOCATION = Location,",
				"          EMAIL_ADDRESS = {Email Address},",
				"          DATE_STARTED_IN_JOB = DATE_STARTED_IN_JOB_ESR,",
				"          ASSIGNMENT_TYPE = {Assignment Category},",
				"          ASSIGNMENT_STATUS = {Assignment Status},",
				"          FTE = FTE_FORMATTED,",
				"          DATE_LEFT_JOB = DATE_LEFT_JOB_ESR,",
				"          TERMINATION_DATE,",
				"          LEAVE_START_DATE,",
				"          LEAVE_END_DATE,",
				"          SUPERVISOR = Supervisor,",
				"          SUPERVISOR_EMPLOYEE_NUMBER = {Supervisor Employee Number},",
				"          SUPERVISOR_ASSIGNMENT_NUMBER = {Supervisor Assignment Number},",
				"          SUPERVISOR_EMAIL_ADDRESS = {Supervisor Email Address},",
				"          LINE_MANAGER_PUID,",
				"          LINE_MANAGER_EMPLOYEE_NUMBER,",
				"          LINE_MANAGER_ASSIGNMENT_NUMBER,",
				"          LINE_MANAGER_EMAIL_ADDRESS,",
				"          LINE_MANAGER_POSITION,",
				"          LINE_MANAGER_NAME,",
				"          POSITION_NUMBER = {Position Number},",
				"          FORMAL_JOB_TITLE = {Position Title (Summary)},",
				"          KNOWN_AS_JOB_TITLE = {Position Title},",
				"          AREA_OF_WORK = {Area Of Work},",
				"          JOB_STAFF_GROUP = {Staff Group},",
				"          JOB_ROLE = Role,",
				"          OCCUPATION_CODE = OCCUPATION_CODE_PADDED,",
				"          HIRING_STATUS = {Hiring Status},",
				"          WORKPLACE_ORG_NAME = {Workplace Org Name},",
				"          PRIMARY_AREA_OF_WORK = {Primary Area of Work},",
				"          SECONDARY_AREA_OF_WORK = {Secondary Area of Work},",
				"          DEPARTMENT = DEPARTMENT_DERIVED,",
				"          OFFICE_LOCATION_NAME = {Location Name},",
				"          OFFICE_LOCATION_ID,",
				"          OFFICE_LOCATION_ADDRESS,",
				"          ASSIGNMENT_ADDRESS_1ST_LINE,",
				"          ASSIGNMENT_ADDRESS_2ND_LINE,",
				"          ASSIGNMENT_ADDRESS_3RD_LINE,",
				"          TOWN,",
				"          LOCATION_COUNTY,",
				"          POSTCODE,",
				"          COUNTRY,",
				"          LOCATION_DESCRIPTION,",
				"          EC_NAME,",
				"          EC_PHONE,",
				"          EC_ADDRESS,",
				"          EC_EMAIL,",
				"          EC_RELATIONSHIP,",
				"          NOK_FORENAME,",
				"          NOK_SURNAME,",
				"          NOK_PHONE,",
				"          NOK_EMAIL,",
				"          NOK_ADDRESS,",
				"          NOK_RELATIONSHIP,",
				"          PARENT_ORGANISATION = PARENT_ORGANISATION_BLANK",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SelectPatientPrivacy",
				"SelectActiveStaff filter(toInteger(TRUST_VPD) == $vpd_code) ~> FilterVPDStaff",
				"SelectPatientPrivacy filter(toInteger(TRUST_VPD) == $vpd_code) ~> FilterVPDPP",
				"SelectActiveStaff sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SinkStaffAll",
				"FilterVPDStaff sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SinkStaffVPD",
