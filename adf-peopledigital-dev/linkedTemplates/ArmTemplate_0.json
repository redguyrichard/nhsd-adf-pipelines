					"referenceName": "ls_adls_stnhsdwidev",
					"type": "LinkedServiceReference"
				},
				"parameters": {
					"p_filename": {
						"type": "String",
						"defaultValue": "20260319_ActiveStaffFull_Azure_All.csv"
					},
					"p_folder": {
						"type": "String",
						"defaultValue": "actives/staff/all"
					}
				},
				"annotations": [],
				"type": "DelimitedText",
				"typeProperties": {
					"location": {
						"type": "AzureBlobFSLocation",
