		},
		"ls_sqldb_sqldb-nhsdwi-dev_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_sqldb_sqldb-nhsdwi-dev'",
			"defaultValue": "Integrated Security=False;Encrypt=True;Connection Timeout=30;Data Source=sql-nhsdwi-dev.database.windows.net;Initial Catalog=sqldb-nhsdwi-dev"
		},
		"ls_adls_stnhsdwidev_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stnhsdwidev.dfs.core.windows.net"
		}
